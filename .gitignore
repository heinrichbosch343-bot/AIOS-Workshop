# ============================================================
# AIOS Workspace — .gitignore
# Files and folders that should NEVER be committed to Git.
# This protects your secrets, avoids bloat, and keeps your
# repository clean.
# ============================================================

# --- Credentials (CRITICAL — never commit these) ---
.env
credentials/
credentials.json
token.json
token_write.json
*.pem
*.key

# --- Demo extraction cache (regenerable; can be re-warmed) ---
demos/invoice-extraction/.cache/

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- Data (generated — reproducible from collection scripts) ---
data/*.db
data/*.db-journal
data/*.db-shm
data/*.db-wal
data/*.log
data/*.pid
data/*.json
data/command/

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- IDE ---
.vscode/
.idea/

# --- Google Takeout exports ---
takeout-*/

# --- Temp files ---
*.tmp
*.bak

# --- Node (if applicable) ---
node_modules/
