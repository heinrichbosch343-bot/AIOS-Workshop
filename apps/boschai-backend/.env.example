# ============================================================
# BoschAI Backend — environment template
# Copy to `.env` (same folder) and fill in. NEVER commit .env.
# ============================================================

# --- REQUIRED (the app will not boot without these) ---

# Supabase (the BoschAI project — separate from any client project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (the brain)
ANTHROPIC_API_KEY=

# Telegram — the BoschAI bot (created via @BotFather) and Heinrich's chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Where the DAILY BRIEF is posted. Leave empty to send it to your DM (TELEGRAM_CHAT_ID).
# To post the brief into a group: add the bot to the group, then put the group's chat id
# here (a negative number, e.g. -1001234567890).
TELEGRAM_BRIEF_CHAT_ID=

# Which TAB (topic) inside that group the brief lands in. Groups with Topics enabled give
# each tab a numeric id. Leave empty to post to the group's General tab. To get it: run
# /myid inside the Daily Brief tab and the bot replies with the value to paste here.
TELEGRAM_BRIEF_TOPIC_ID=

# Any random long string — protects the dashboard/API endpoints
API_SECRET_KEY=

# --- LOCAL-FIRST TOGGLE ---
# Set to 1 to run the API WITHOUT starting the Telegram bot (useful while two bots
# could clash, or for a code-only boot). Set to 0 / leave unset to run the bot.
DISABLE_TELEGRAM_BOT=0

# Extra Telegram chat ids allowed to talk to the bot (comma-separated).
# Leave empty to allow only TELEGRAM_CHAT_ID. Add the BoschAI group id here if used.
ALLOWED_TELEGRAM_CHATS=

# --- OPTIONAL: Google Drive (Knowledge Pool, dormant until needed) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- OPTIONAL: Deep Research (web search + scraping) ---
FIRECRAWL_API_KEY=

# --- OPTIONAL: Knowledge Pool embeddings (semantic doc search, dormant) ---
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-law-2
EMBEDDING_DIM=1024
POOL_CLIENT_ROOTS=
EMBED_BATCH_SIZE=8
EMBED_REQUEST_INTERVAL=20

# --- ADDED BY LANE B (follow-up engine) — leave here; Lane B fills these in ---
 FOLLOWUP_ENABLED=0
 FOLLOWUP_ALLOWLIST=
 FOLLOWUP_DELAY_DAYS=3
 FOLLOWUP_DAILY_CAP=10
 FOLLOWUP_KILL_SWITCH=0
 FOLLOWUP_WARMUP=1
